{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/downloads/android-update.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/downloads/mairide-android.apk",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"mairide-android.apk\""
        }
      ]
    },
    {
      "source": "/downloads/android.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/downloads/ios/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "mairide.in"
        }
      ],
      "destination": "/landing.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.mairide.in"
        }
      ],
      "destination": "/landing.html"
    },
    {
      "source": "/downloads/ios",
      "destination": "/downloads/ios/index.html"
    },
    {
      "source": "/downloads/mairide-android-download.apk",
      "destination": "/downloads/mairide-android.apk"
    },
    {
      "source": "/((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": "rides.mairide.in"
        }
      ],
      "destination": "/index.html"
    }
  ]
}
